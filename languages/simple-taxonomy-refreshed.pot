#: includes/class-simpletaxonomyrefreshed-admin-conversion.php:421
msgid "Phase One"
msgstr ""

#: includes/class-simpletaxonomyrefreshed-admin-conversion.php:422, includes/class-simpletaxonomyrefreshed-admin-import.php:320
